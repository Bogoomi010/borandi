{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "MVP 최소 권한: core 기본 + 창 닫기/전체화면. fs/shell/network는 열지 않는다.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen"
  ]
}
